##############################################################################
import os

from sequana_pipetools import snaketools as sm

# This must be defined before the include
configfile: "config.yaml"


# Sample names come from filenames up to the first dot. LIMA outputs share a
# common "lima_output." prefix which is stripped so barcode IDs drive the
# sample names (e.g. lima_output.lbc32--lbc32.ccs.bam -> lbc32--lbc32).
manager = sm.PipelineManager(
    "pacbio_qc", config, extra_prefixes_to_strip=["lima_output."]
)


# ========================================================= Final results
rule pipeline:
    input:
        expand("{sample}/summary.html", sample=manager.samples),
        ".sequana/rulegraph.svg",
        "multiqc/multiqc_report.html",
        "summary.json",


# ========================================================= pacbio QC (per sample)
rule pacbio_quality:
    input:
        manager.getrawdata(),
    output:
        "{sample}/sequana_summary_pacbio_qc_{sample}.json",
    log:
        "{sample}/pacbio_quality.log",
    run:
        from sequana import pacbio

        p = pacbio.PacbioSubreads(input[0])
        p.save_summary(output[0])
        # embed the sample name so the plotting_and_stats rule can key on it
        import json

        with open(output[0]) as fh:
            data = json.load(fh)
        data["sample"] = wildcards.sample
        with open(output[0], "w") as fh:
            json.dump(data, fh, indent=4, sort_keys=True)


# ========================================================= bam to fasta (for kraken)
if config["kraken"]["do"]:

    rule bam_to_fasta:
        input:
            manager.getrawdata(),
        output:
            temp("tmp/{sample}.fasta"),
        log:
            "{sample}/bam_to_fasta.log",
        threads: config["bam_to_fasta"]["thread"]
        run:
            from sequana import pacbio

            p = pacbio.PacbioSubreads(input[0])
            p.to_fasta(output[0], threads=threads)


# ========================================================= kraken
extra_kraken = []
html_report_extra_input = []
if config["kraken"]["do"]:
    extra_kraken = expand("{sample}/kraken/kraken.html", sample=manager.samples)
    html_report_extra_input = ["{sample}/kraken/kraken.html"]

    rule kraken:
        input:
            "tmp/{sample}.fasta",
        output:
            "{sample}/kraken/kraken.html",
        params:
            databases=config["kraken"]["databases"],
        threads: config["kraken"]["thread"]
        log:
            "{sample}/kraken/kraken.log",
        run:
            dbs = " ".join(params.databases)
            shell(
                "sequana_taxonomy --file1 {input} --output-directory {wildcards.sample} "
                "--thread {threads} --databases " + dbs + " > {log} 2>&1"
            )


# ========================================================= per-sample HTML report
rule html_report:
    input:
        ["{sample}/sequana_summary_pacbio_qc_{sample}.json"] + html_report_extra_input,
    output:
        "{sample}/summary.html",
    params:
        dir_kraken="{sample}/kraken",
        dir="{sample}",
    message:
        "create the pacbio BAM QC summary page"
    run:
        from sequana.modules_report.pacbio_input_bam import PacbioInputBAMModule as Module
        from sequana.utils import config as cfg

        # redirect module output into the sample directory
        buffer = cfg.output_dir
        cfg.output_dir = params.dir
        m = Module(input[0])
        cfg.output_dir = buffer

        # rebuild in the original directory (creates css/images/js at top level,
        # cleaned up in onsuccess)
        m = Module(input[0])

        if config["kraken"]["do"]:
            from sequana.modules_report.kraken import KrakenModule

            kr = KrakenModule(params.dir_kraken, output_filename=None)
            html = kr._get_summary_section()
            m.sections.append(
                {
                    "name": "Taxonomic content",
                    "anchor": "kraken",
                    "content": html,
                }
            )
        m.create_html(output[0])


# ========================================================= multiqc
sequana_multiqc_input = (
    expand("{sample}/sequana_summary_pacbio_qc_{sample}.json", sample=manager.samples)
    + extra_kraken
)


rule multiqc:
    input:
        sequana_multiqc_input,
    output:
        "multiqc/multiqc_report.html",
    params:
        options=config["multiqc"]["options"],
        input_directory=config["multiqc"]["input_directory"],
        config_file=config["multiqc"]["config_file"],
        modules=config["multiqc"]["modules"],
    log:
        "multiqc/multiqc.log",
    container:
        config["apptainers"]["multiqc"]
    shell:
        manager.get_shell("multiqc/run", "v1")


# ========================================================= plotting & stats
rule plotting_and_stats:
    input:
        expand("{sample}/sequana_summary_pacbio_qc_{sample}.json", sample=manager.samples),
    output:
        "summary.json",
    log:
        "plotting_and_stats.log",
    run:
        import json
        from sequana.summary import Summary
        from sequana_pipelines.pacbio_qc import version

        summary = Summary(
            "pacbioqc", caller="sequana_pacbio_qc", sample_name="multi samples"
        )
        summary.description = "summary sequana_pacbio_qc pipeline"
        summary.pipeline_version = version

        for filename in input:
            data = json.load(open(filename, "r"))
            sample = data["sample"]
            summary.data[sample] = data["read_stats"]
            summary.data[sample]["sample"] = sample

        summary.to_json("summary.json")


# ========================================================= rulegraph
rule rulegraph:
    input:
        str(manager.snakefile),
    output:
        temp("rulegraph/rulegraph.dot"),
    params:
        mapper={"multiqc": "../multiqc/multiqc_report.html"},
        configname="config.yaml",
    run:
        manager.get_run("rulegraph/run", "v1")(input, output, params)


rule dot2svg:
    input:
        "rulegraph/rulegraph.dot",
    output:
        ".sequana/rulegraph.svg",
    container:
        config["apptainers"]["graphviz"]
    shell:
        manager.get_shell("graphviz/dot2svg", "v1")


localrules:
    rulegraph,
    dot2svg,
    html_report,
    plotting_and_stats,


onsuccess:
    import json

    import pandas as pd
    from sequana import logger
    from sequana.modules_report.summary import SequanaReport
    from sequana.utils.datatables_js import DataTable

    from sequana_pipelines.pacbio_qc import version as vv

    logger.setLevel("INFO")

    manager.teardown()

    # Module() calls create these at the top level; they are embedded in the
    # per-sample summary so we can remove them.
    shell("rm -rf css images js")

    # Summary table with links to per-sample pages
    data = json.load(open("summary.json", "r"))
    df = pd.DataFrame(data["data"]).T
    if "sample" in df.columns:
        del df["sample"]
    df = df.reset_index().rename({"index": "sample"}, axis=1)

    for col in ["count", "nb_reads", "nb_bases", "min", "max"]:
        try:
            df[col] = [int(x) for x in df[col]]
        except Exception:
            pass
    for col in ["mean", "mean_GC", "std", "mean_passes"]:
        try:
            df[col] = [round(float(x), 2) for x in df[col]]
        except Exception:
            pass
    for col in ["25%", "50%", "75%", "count"]:
        if col in df.columns:
            del df[col]
    df = df.rename(
        {
            "min": "min_read_length",
            "max": "max_read_length",
            "std": "std_read_length",
            "mean": "mean_length",
        },
        axis=1,
    )
    df["link"] = ["{}/summary.html".format(x) for x in df["sample"]]

    datatable = DataTable(df, "pacbio_qc", index=False)
    datatable.datatable.datatable_options = {
        "paging": "false",
        "buttons": ["copy", "csv"],
        "bSort": "true",
        "dom": "BRSPfrti",
    }
    datatable.datatable.set_links_to_column("link", "sample")
    js = datatable.create_javascript_function()
    htmltable = datatable.create_datatable()

    # Top general-info table
    df_general = pd.DataFrame(
        {"samples": len(manager.samples), "sequana_pacbio_qc_version": vv},
        index=["summary"],
    )
    datatable = DataTable(df_general.T, "general", index=True)
    datatable.datatable.datatable_options = {
        "paging": "false",
        "bFilter": "false",
        "bInfo": "false",
        "header": "false",
        "bSort": "true",
    }
    js2 = datatable.create_javascript_function()
    htmltable2 = datatable.create_datatable(style="width: 20%; float:left")

    contents = "<h2>General information</h2>"
    contents += '<div style="float:left; width:30%">{}</div>'.format(js2 + htmltable2)
    contents += (
        "<p>Here below you can find a summary table with basic statistics about "
        "your reads. Click on the links in the first column to jump to a "
        "per-sample summary (histograms and, if enabled, Kraken taxonomy).</p>"
    )
    contents += '<div style="clear:both"></div>'
    contents += (
        '<hr>See the <b><a href="multiqc/multiqc_report.html">multiqc report</a></b>'
        " for details about your run.<br>"
    )
    contents += (
        "<br><hr><div>Summary for all samples. The CSV button exports the basic "
        "statistics. {}</div>".format(js + htmltable)
    )

    data = manager.getmetadata()
    SequanaReport(data, intro=contents)

    shell("chmod -R g+w .")


onerror:
    manager.onerror()
